<!DOCTYPE html>
<html lang="fr">
  <head>

    <% if @post %>
      <% image_url = @post.photos.first.key if @post.photos.any? %>
    <% elsif params[:tag].present? && @posts.any? %>
      <% image_url = @posts.first.photos.first.key if @posts.first.photos.any? %>
    <% else %>
      <% image_url = asset_path('portrait-quentin-orhant.jpg') %>
    <% end %>

    <% title_content = "Quentin Orhant - Écologeek | Maker | Développeur#{@post ? " - #{@post.title}" : (@page_title ? " - #{@page_title}" : "")}" %>
    <% description_content = @meta_description || "Quentin Orhant : Expert freelance en éco-conception d’objets et de services..." %>
    <% page_url = request.original_url %>

    <title><%= title_content %></title>
    <meta name="description" content="<%= description_content %>">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">

    <meta property="og:title" content="<%= title_content %>" />
    <meta property="og:description" content="<%= description_content %>" />
    <meta property="og:image" content="<%= image_url %>" />
    <meta property="og:url" content="<%= page_url %>" />

    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", defer: true %>
    <%= favicon_link_tag "favicon.ico", rel: "icon" %>
    <script defer src="https://app.tinyanalytics.io/pixel/2NvQLdPcP9PonJgK"></script>
  </head>
  <body data-hijacking="off" data-animation="none">
    <%= render "shared/tagsbar" %>
    <%= render "shared/navbar" %>
    <%= render "shared/tagsline" %>
    <%= render "shared/flashes" %>
    <div class="container">
      <%= yield %>
    <div class="footer">
      <%= link_to "https://collectif.greenit.fr/ecoconception-web/", class: "footer", title: "lien vers greenIT - référenciel d'éco-conception web", target: "_blank" do %>
        <p class= "footer-text"> Site réalisé en respectant les principes de l'éco-conception web</p>
      <% end %>
    </div>
  </body>
</html>
